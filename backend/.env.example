# ===========================================
# CPDC Inventory System - Backend Configuration
# ===========================================

# ===========================================
# REQUIRED CONFIGURATION
# ===========================================

# MongoDB Connection (IMPORTANT: Update for production)
MONGODB_URI=mongodb://localhost:27017/cpdc-inventory

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL for CORS (update in production)
CLIENT_URL=http://localhost:5173

# JWT Secrets (IMPORTANT: Generate strong random secrets for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters recommended
JWT_ACCESS_SECRET=your-access-secret-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production

# Optional: Token expiration times
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ===========================================
# SECURITY FEATURES (Optional)
# ===========================================

# Cloudflare Turnstile CAPTCHA (optional)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# If set, login requires a valid Turnstile token
# TURNSTILE_SECRET_KEY=

# Sentry Error Monitoring (optional)
# Get DSN from: https://sentry.io/settings/projects/
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ===========================================
# EMAIL SERVICE (Optional - Brevo)
# ===========================================

# Brevo (transactional email) - https://www.brevo.com/
# Get your API key from: Brevo dashboard → SMTP & API → API Keys
BREVO_API_KEY=

# Optional: sender shown in emails (must be a verified sender in Brevo)
EMAIL_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM_NAME=CPDC Inventory

# Optional: Brevo template IDs (from Brevo → Transactional → Templates)
# If set, these replace built-in emails
# Welcome / account created (params: {{ params.NAME }}, {{ params.TEMP_PASSWORD }})
# BREVO_TEMPLATE_WELCOME=0
# Verification OTP (params: {{ params.NAME }}, {{ params.OTP }}, {{ params.EXPIRY_HOURS }})
# BREVO_TEMPLATE_VERIFICATION=1
# Password reset OTP (params: {{ params.NAME }}, {{ params.OTP }}, {{ params.EXPIRY_MINUTES }})
# BREVO_TEMPLATE_PASSWORD_RESET=2
# Admin password reset notification (params: {{ params.NAME }})
# BREVO_TEMPLATE_ADMIN_PASSWORD_RESET=3

# ===========================================
# ADMIN SEED CONFIGURATION
# ===========================================

# Initial admin account (used by seedAdmin.js script)
SEED_ADMIN_EMAIL=admin@cpdc.example.com
SEED_ADMIN_PASSWORD=ChangeThisSecurePassword123!
SEED_ADMIN_NAME=System Administrator

# ===========================================
# NOTES
# ===========================================
# 1. NEVER commit .env file with real secrets to version control
# 2. Copy this file to .env and update with your actual values
# 3. In production, use strong random secrets for JWT keys
# 4. Update CLIENT_URL to match your frontend deployment URL
# 5. Enable security features (Turnstile, Sentry) for production
