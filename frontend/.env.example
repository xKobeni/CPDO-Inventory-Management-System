# ===========================================
# CPDC Inventory System - Frontend Configuration
# ===========================================

# API base URL (no trailing slash). Used at build time for Vite.
# Development: backend usually at http://localhost:5000/api
# Production: set to your deployed API URL, e.g. https://api.yourdomain.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# ===========================================
# SECURITY FEATURES (Optional)
# ===========================================

# Cloudflare Turnstile CAPTCHA (optional)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# If set, login form shows the Turnstile widget
# Backend must also have TURNSTILE_SECRET_KEY configured
# VITE_TURNSTILE_SITE_KEY=

# Sentry Error Monitoring (optional)
# Get DSN from: https://sentry.io/settings/projects/
# Create a separate React project in Sentry for frontend
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ===========================================
# NOTES
# ===========================================
# 1. NEVER commit .env file to version control
# 2. Copy this file to .env and update with your values
# 3. All environment variables must start with VITE_ to be exposed to the app
# 4. Changes require rebuild (npm run dev or npm run build)
# 5. Update VITE_API_BASE_URL in production to match your backend URL
